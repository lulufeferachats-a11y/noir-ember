# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noir_ember

# Server
PORT=4000
NODE_ENV=development

# CORS - comma separated list of allowed origins
CLIENT_ORIGIN=http://localhost:5173

# Admin dashboard auth (simple shared secret for MVP - replace with real auth for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production

# Restaurant tenant id (used to load the correct config for this deployment)
RESTAURANT_SLUG=noir-and-ember
